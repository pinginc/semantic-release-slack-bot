    "conventional-changelog-conventionalcommits": "^9.0.0",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "mocha": "^11.0.0",
    "nock": "^14.0.11",
    "nyc": "^18.0.0",
